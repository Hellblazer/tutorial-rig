{
  "session": "e2e-test",
  "agent": {
    "command": "Compute 17 plus 26 and reply with exactly one line in the form: NUM=<answer>. Show only that line.",
    "cwd": "/tmp",
    "bypass_permissions": true,
    "extra_args": ["--model", "haiku"]
  },
  "hooks": { "capture_tools": [] },
  "gates": [],
  "validate": {
    "must_contain": ["NUM=43"],
    "must_not_contain": ["step_aborted", "failure_reason"]
  },
  "pacing": {
    "idle_seconds": 6,
    "attach_gap_sec": 8,
    "agent_done_hold_sec": 4,
    "exit_hold_sec": 4,
    "tmux_size": "160x40"
  },
  "render": { "font_size": 20, "theme": "monokai" }
}
