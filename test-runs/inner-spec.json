{
  "session": "inner-spec",
  "agent": {
    "command": "Compute 11 plus 22 and reply with exactly one line: NUM=<answer>. Show only that line.",
    "cwd": "/tmp",
    "bypass_permissions": true,
    "extra_args": ["--model", "haiku"]
  },
  "hooks": { "capture_tools": [] },
  "gates": [],
  "validate": {
    "must_contain": ["NUM=33"],
    "must_not_contain": ["step_aborted", "failure_reason"]
  },
  "pacing": {
    "idle_seconds": 6,
    "turn_timeout_sec": 90,
    "attach_gap_sec": 6,
    "agent_done_hold_sec": 4,
    "exit_hold_sec": 4,
    "tmux_size": "160x40"
  },
  "render": { "font_size": 18, "theme": "monokai" }
}
