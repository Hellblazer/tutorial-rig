{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "touch /tmp/__SESSION__.prompt-submitted" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "touch /tmp/__SESSION__.turn-end" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          { "type": "command", "command": "touch /tmp/__SESSION__.gate-pending" }
        ]
      }
    ],
    "PostToolUse": __CAPTURE_TOOLS__,
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "touch /tmp/__SESSION__.session-start" }
        ]
      }
    ]
  }
}
