{
  "session": "rig-example-gated",
  "agent": {
    "command": "/nx:brainstorming-gate add a /hello command that prints a greeting"
  },
  "hooks": {
    "capture_tools": []
  },
  "gates": [
    { "wait_for": "gate-pending", "answer_index": 1, "pre_enter_sec": 5, "post_enter_sec": 2 },
    { "wait_for": "gate-pending", "answer_index": 1, "pre_enter_sec": 5, "post_enter_sec": 2 }
  ],
  "validate": {
    "must_contain": ["brainstorm"],
    "must_not_contain": ["step_aborted", "failure_reason"]
  },
  "pacing": {
    "idle_seconds": 8,
    "agg_idle_time_limit": 4,
    "exit_hold_sec": 8,
    "tmux_size": "200x55"
  }
}
