{
  "session": "rig-example-single",
  "agent": {
    "command": "/nx:query how does the T3 storage tier work in nexus?",
    "cwd": ".",
    "extra_args": []
  },
  "hooks": {
    "capture_tools": []
  },
  "gates": [],
  "validate": {
    "must_contain": ["T3", "chromadb"],
    "must_not_contain": ["Error:", "step_aborted", "failure_reason"]
  },
  "pacing": {
    "idle_seconds": 8,
    "agg_idle_time_limit": 4,
    "exit_hold_sec": 6,
    "tmux_size": "180x50"
  }
}
