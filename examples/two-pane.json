{
  "session": "rig-example-twopane",
  "agent": {
    "command": "/my-skill:start kick off the background job",
    "bypass_permissions": true
  },
  "hooks": {
    "capture_tools": [
      {
        "name": "job-id",
        "matcher": "^mcp__.*__start_job$",
        "jq": ".job_id // .jobId"
      }
    ]
  },
  "gates": [],
  "companion": {
    "command": "node",
    "args": ["observer.mjs"],
    "wait_for_sentinels": ["job-id"],
    "env": { "JOB_ID": "$job-id" }
  },
  "validate": {
    "must_contain": ["job complete"],
    "must_not_contain": ["step_aborted", "failure_reason"]
  },
  "pacing": {
    "idle_seconds": 8,
    "turn_timeout_sec": 120,
    "attach_gap_sec": 4,
    "agent_done_hold_sec": 4,
    "exit_hold_sec": 8,
    "tmux_size": "220x55"
  }
}
